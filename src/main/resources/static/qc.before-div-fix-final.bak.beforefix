<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TGMS - Quality Control Management</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  </head>
<body>
<header class="header">
    <div class="container">
        <div class="header-content">
            <h1 class="logo">TGMS</h1>
            <nav class="nav">
                <a href="roles.html" class="nav-link">Roles</a>
                <a href="dashboard.html" class="nav-link">Production</a>
                <a href="index.html#app" class="nav-link">Sales & Orders</a>
                <a href="hr.html" class="nav-link">HR</a>
                <a href="qc.html" class="nav-link active">Quality</a>
                <a href="attendance.html" class="nav-link">Attendance</a>
                <a href="support.html" class="nav-link">Support</a>
            </nav>
            <div class="user-menu">
                <span class="user-name">QC Manager</span>
                <a href="login.html" class="logout-btn">Logout</a>
            </div>
        </div>
    </div>
</header>

<main class="main">
    <div class="container">
        <div class="section-header">
            <h2><i class="fas fa-clipboard-check"></i> Quality Control Management</h2>
            <button class="btn btn-primary" id="openAddModal"><i class="fas fa-plus"></i> New Inspection Report</button>
        </div>

        <div class="qc-grid">
            <div class="qc-card pass">
                <div class="qc-title">Overall Quality Score</div>
                <div class="metric">94.5%</div>
                <div class="qc-score">Last 7 days</div>
            </div>
            <div class="qc-card">
                <div class="qc-title">Inspections Today</div>
                <div class="metric">12</div>
                <div class="qc-score">Across all products</div>
            </div>
            <div class="qc-card pass">
                <div class="qc-title">Pass Rate</div>
                <div class="metric">91.3%</div>
                <div class="qc-score">This month</div>
            </div>
            <div class="qc-card fail">
                <div class="qc-title">Defect Rate</div>
                <div class="metric">2.1%</div>
                <div class="qc-score">This month</div>
            </div>
        </div>

        <div class="filters">
            <div class="filter-group">
                <input class="search-input" type="text" placeholder="Search inspection reports...">
                <select class="filter-select">
                    <option>All Results</option>
                    <option>Passed</option>
                    <option>Failed</option>
                    <option>Pending</option>
                </select>
                <select class="filter-select">
                    <option>All Products</option>
                    <option>T-Shirts</option>
                    <option>Jeans</option>
                    <option>Polo Shirts</option>
                </select>
            </div>
        </div>

        <div class="table-container">
            <table class="data-table">
                <thead>
                <tr>
                    <th>Report ID</th>
                    <th>Batch ID</th>
                    <th>Product</th>
                    <th>Inspector</th>
                    <th>Inspection Date</th>
                    <th>Quality Score</th>
                    <th>Result</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>QR-2025-001</td>
                    <td>B-456</td>
                    <td>Cotton T-Shirts</td>
                    <td>Mike Johnson</td>
                    <td>2025-01-20</td>
                    <td>95.2%</td>
                    <td><span class="status-badge status-confirmed">Passed</span></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-secondary btn-sm action-btn view"><i class="fas fa-eye"></i> View</button>
                            <button class="btn btn-warning btn-sm action-btn edit"><i class="fas fa-pen"></i> Edit</button>
                            <button class="btn btn-danger btn-sm action-btn delete"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>QR-2025-002</td>
                    <td>B-457</td>
                    <td>Denim Jeans</td>
                    <td>Sarah Wilson</td>
                    <td>2025-01-19</td>
                    <td>87.8%</td>
                    <td><span class="status-badge status-cancelled">Failed</span></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-secondary btn-sm action-btn view"><i class="fas fa-eye"></i> View</button>
                            <button class="btn btn-warning btn-sm action-btn edit"><i class="fas fa-pen"></i> Edit</button>
                            <button class="btn btn-danger btn-sm action-btn delete"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>QR-2025-003</td>
                    <td>B-458</td>
                    <td>Polo Shirts</td>
                    <td>David Brown</td>
                    <td>2025-01-21</td>
                    <td>-</td>
                    <td><span class="status-badge status-pending">Pending</span></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-secondary btn-sm action-btn view"><i class="fas fa-eye"></i> View</button>
                            <button class="btn btn-warning btn-sm action-btn edit"><i class="fas fa-pen"></i> Edit</button>
                            <button class="btn btn-danger btn-sm action-btn delete"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>

    </div>
</main>

<footer class="footer">
    <div class="container">
        <p>&copy; 2025 TGMS - Developed by SLIIT Team | SE2030 Software Engineering</p>
    </div>
</footer>

<!-- Add New Inspection Report Modal -->
<div id="addInspectionModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-clipboard-list"></i> Add New Inspection Report</h3>
            <span class="close" data-close="addInspectionModal">&times;</span>
        </div>
        <div class="modal-body">
            <form id="addInspectionForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="batchId">Batch ID</label>
                        <input type="text" id="batchId" name="batchId" required>
                    </div>
                    <div class="form-group">
                        <label for="product">Product</label>
                        <input type="text" id="product" name="product" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="inspector">Inspector</label>
                        <input type="text" id="inspector" name="inspector" required>
                    </div>
                    <div class="form-group">
                        <label for="inspectionDate">Inspection Date</label>
                        <input type="date" id="inspectionDate" name="inspectionDate" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="qualityScore">Quality Score (%)</label>
                        <input type="number" id="qualityScore" name="qualityScore" min="0" max="100" step="0.1">
                    </div>
                    <div class="form-group">
                        <label for="result">Result</label>
                        <select id="result" name="result" required>
                            <option value="Passed">Passed</option>
                            <option value="Failed">Failed</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                                                    <div class="form-group">
                    <label for="inspectionPhoto">Inspection Photo</label>
                    <input type="file" id="inspectionPhoto" name="inspectionPhoto" accept="image/*">
                    <div style="margin-top:10px;">
                        <img id="photoPreview" alt="Preview" style="display:none; max-height:140px; border-radius:8px; border:1px solid #ecf0f1;" />
                    </div>
                </div>
                <div class="form-group">
                    <label for="notes">Inspection Notes</label>
                    <textarea id="notes" name="notes" rows="3"></textarea>
                </div><div class="form-actions">
                    <button type="button" class="secondary-btn close-popup-btn">Cancel</button>
                    <button type="submit" class="primary-btn">Save Inspection Report</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Inspection Report Popup -->
<div id="viewInspectionPopup" class="popup">
    <div class="popup-content">
        <div class="popup-header">
            <h3>Inspection Report Details</h3>
            <span class="close-popup">&times;</span>
        </div>
        <div class="popup-body">
            <div class="employee-details">
                <div class="detail-item">
                    <span class="detail-label">Report ID</span>
                    <span id="viewReportId" class="detail-value">QR-2025-001</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Batch ID</span>
                    <span id="viewBatchId" class="detail-value">B-456</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Product</span>
                    <span id="viewProduct" class="detail-value">Cotton T-Shirts</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Inspector</span>
                    <span id="viewInspector" class="detail-value">Mike Johnson</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Inspection Date</span>
                    <span id="viewInspectionDate" class="detail-value">2025-01-20</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Quality Score</span>
                    <span id="viewQualityScore" class="detail-value">95.2%</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Result</span>
                    <span id="viewResult" class="detail-value"><span class="status passed">Passed</span></span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Notes</span>
                    <span id="viewNotes" class="detail-value">All quality metrics passed. Minor improvements needed in stitching.</span>
                </div>
            </div>
            <div class="form-actions">
                <button type="button" class="secondary-btn close-popup-btn">Close</button>
                <button type="button" class="primary-btn edit-inspection-btn">Edit</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Inspection Report Popup -->
<div id="editInspectionPopup" class="popup">
    <div class="popup-content">
        <div class="popup-header">
            <h3>Edit Inspection Report</h3>
            <span class="close-popup">&times;</span>
        </div>
        <div class="popup-body">
            <form id="editInspectionForm">
                <input type="hidden" id="editReportId" name="editReportId" value="QR-2025-001">
                <div class="form-row">
                    <div class="form-group">
                        <label for="editBatchId">Batch ID</label>
                        <input type="text" id="editBatchId" name="editBatchId" value="B-456" required>
                    </div>
                    <div class="form-group">
                        <label for="editProduct">Product</label>
                        <input type="text" id="editProduct" name="editProduct" value="Cotton T-Shirts" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="editInspector">Inspector</label>
                        <input type="text" id="editInspector" name="editInspector" value="Mike Johnson" required>
                    </div>
                    <div class="form-group">
                        <label for="editInspectionDate">Inspection Date</label>
                        <input type="date" id="editInspectionDate" name="editInspectionDate" value="2025-01-20" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="editQualityScore">Quality Score (%)</label>
                        <input type="number" id="editQualityScore" name="editQualityScore" value="95.2" min="0" max="100" step="0.1">
                    </div>
                    <div class="form-group">
                        <label for="editResult">Result</label>
                        <select id="editResult" name="editResult" required>
                            <option value="Passed" selected>Passed</option>
                            <option value="Failed">Failed</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="editNotes">Inspection Notes</label>
                    <textarea id="editNotes" name="editNotes" rows="3">All quality metrics passed. Minor improvements needed in stitching.</textarea>
                </div>
                <div class="form-actions">
                    <button type="button" class="secondary-btn close-popup-btn">Cancel</button>
                    <button type="submit" class="primary-btn">Update Inspection Report</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Popups
  const addInspectionPopup = document.getElementById('addInspectionPopup');
  const viewInspectionPopup = document.getElementById('viewInspectionPopup');
  const editInspectionPopup = document.getElementById('editInspectionPopup');

  // Table
  const tbody = document.querySelector('.data-table tbody');
  let currentEditId = null;

  function badgeClass(result) {
    if (result === 'Passed') return 'status-confirmed';
    if (result === 'Failed') return 'status-cancelled';
    return 'status-pending';
  }

  async function loadInspections() {
    try {
      const res = await fetch('/api/quality/inspections');
      if (!res.ok) throw new Error('Failed to load inspections');
      const data = await res.json();
      tbody.innerHTML = (data || []).map(i => {
        const scoreText = i.qualityScore != null ? `${Number(i.qualityScore).toFixed(1)}%` : '-';
        const dateText = (i.inspectionDate || '').toString();
        return `
          <tr data-id="${i.id}">
            <td>${i.reportId || '-'}</td>
            <td>${i.batchId || '-'}</td>
            <td>${i.product || '-'}</td>
            <td>${i.inspector || '-'}</td>
            <td>${dateText}</td>
            <td>${scoreText}</td>
            <td><span class="status-badge ${badgeClass(i.result)}">${i.result || '-'}</span></td>
            <td>
              <div class="action-buttons">
                <button class="btn btn-secondary btn-sm action-btn view"><i class="fas fa-eye"></i> View</button>
                <button class="btn btn-warning btn-sm action-btn edit"><i class="fas fa-pen"></i> Edit</button>
                <button class="btn btn-danger btn-sm action-btn delete"><i class="fas fa-trash"></i> Delete</button>
              </div>
            </td>
          </tr>`;
      }).join('');
    } catch (e) {
      console.error(e);
      tbody.innerHTML = '';
    }
  }

  // Open add modal
  const addInspectionBtn = document.getElementById('openAddModal');
  addInspectionBtn.addEventListener('click', () => { addInspectionPopup.style.display = 'block'; });

  // Close buttons
  document.querySelectorAll('.close-popup, .close-popup-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      addInspectionPopup.style.display = 'none';
      viewInspectionPopup.style.display = 'none';
      editInspectionPopup.style.display = 'none';
    });
  });

  // Photo preview for add form
  const photoInput = document.getElementById('inspectionPhoto');
  const photoPreview = document.getElementById('photoPreview');
  if (photoInput && photoPreview) {
    photoInput.addEventListener('change', function() {
      const f = this.files && this.files[0];
      if (!f) { photoPreview.style.display='none'; photoPreview.src=''; return; }
      const url = URL.createObjectURL(f);
      photoPreview.src = url;
      photoPreview.style.display = 'block';
    });
  }

  // Create
  const addInspectionForm = document.getElementById('addInspectionForm');
  addInspectionForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    const payload = {
      reportId: `QR-${new Date().getFullYear()}-${Math.floor(100 + Math.random()*900)}`,
      batchId: document.getElementById('batchId').value.trim(),
      product: document.getElementById('product').value.trim(),
      inspector: document.getElementById('inspector').value.trim(),
      inspectionDate: document.getElementById('inspectionDate').value,
      qualityScore: document.getElementById('qualityScore').value || null,
      result: document.getElementById('result').value,
      notes: (document.getElementById('notes')||{}).value || ''
    };
    const fd = new FormData();
    fd.append('data', new Blob([JSON.stringify(payload)], { type: 'application/json' }));
    const photoFile = document.getElementById('inspectionPhoto')?.files?.[0];
    if (photoFile) fd.append('photo', photoFile);

    try {
      const res = await fetch('/api/quality/inspections', { method: 'POST', body: fd });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      addInspectionPopup.style.display = 'none';
      addInspectionForm.reset();
      if (photoPreview) { photoPreview.style.display='none'; photoPreview.src=''; }
      await loadInspections();
      alert('Inspection report created.');
    } catch (err) {
      console.error(err);
      alert('Failed to create inspection report.');
    }
  });

  // Delegated row actions: View/Edit/Delete
  tbody.addEventListener('click', async (e) => {
    const btn = e.target.closest('.action-btn');
    if (!btn) return;
    const tr = btn.closest('tr');
    const id = tr ? tr.getAttribute('data-id') : null;
    if (!id) return;

    // View
    if (btn.classList.contains('view')) {
      try {
        const res = await fetch(`/api/quality/inspections/${id}`);
        if (!res.ok) throw new Error('View load failed');
        const i = await res.json();
        document.getElementById('viewReportId').textContent = i.reportId || '-';
        document.getElementById('viewBatchId').textContent = i.batchId || '-';
        document.getElementById('viewProduct').textContent = i.product || '-';
        document.getElementById('viewInspector').textContent = i.inspector || '-';
        document.getElementById('viewInspectionDate').textContent = i.inspectionDate || '-';
        document.getElementById('viewQualityScore').textContent = (i.qualityScore!=null ? Number(i.qualityScore).toFixed(1)+'%' : '-');
        const resSpan = document.getElementById('viewResult');
        if (resSpan) resSpan.innerHTML = `<span class="status ${i.result==='Passed'?'passed': i.result==='Failed'?'failed':'pending'}">${i.result||'-'}</span>`;
        document.getElementById('viewNotes').textContent = i.notes || '';
        viewInspectionPopup.style.display = 'block';
      } catch (err) { console.error(err); alert('Failed to load inspection details'); }
      return;
    }

    // Edit
    if (btn.classList.contains('edit')) {
      try {
        const res = await fetch(`/api/quality/inspections/${id}`);
        if (!res.ok) throw new Error('Edit load failed');
        const i = await res.json();
        currentEditId = id;
        document.getElementById('editReportId').value = i.reportId || '';
        document.getElementById('editBatchId').value = i.batchId || '';
        document.getElementById('editProduct').value = i.product || '';
        document.getElementById('editInspector').value = i.inspector || '';
        document.getElementById('editInspectionDate').value = (i.inspectionDate || '').toString().substring(0,10);
        document.getElementById('editQualityScore').value = i.qualityScore!=null ? i.qualityScore : '';
        document.getElementById('editResult').value = i.result || 'Pending';
        document.getElementById('editNotes').value = i.notes || '';
        editInspectionPopup.style.display = 'block';
      } catch (err) { console.error(err); alert('Failed to load inspection for edit'); }
      return;
    }

    // Delete
    if (btn.classList.contains('delete')) {
      if (!confirm('Are you sure you want to delete this inspection report?')) return;
      try {
        const res = await fetch(`/api/quality/inspections/${id}`, { method: 'DELETE' });
        if (!res.ok && res.status !== 204) throw new Error('Delete failed');
        await loadInspections();
      } catch (err) { console.error(err); alert('Failed to delete'); }
    }
  });

  // Edit submit
  const editInspectionForm = document.getElementById('editInspectionForm');
  editInspectionForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!currentEditId) { alert('No record selected'); return; }
    const payload = {
      reportId: document.getElementById('editReportId').value.trim(),
      batchId: document.getElementById('editBatchId').value.trim(),
      product: document.getElementById('editProduct').value.trim(),
      inspector: document.getElementById('editInspector').value.trim(),
      inspectionDate: document.getElementById('editInspectionDate').value,
      qualityScore: document.getElementById('editQualityScore').value || null,
      result: document.getElementById('editResult').value,
      notes: document.getElementById('editNotes').value || ''
    };
    const fd = new FormData();
    fd.append('data', new Blob([JSON.stringify(payload)], { type: 'application/json' }));
    try {
      const res = await fetch(`/api/quality/inspections/${currentEditId}`, { method: 'PUT', body: fd });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      editInspectionPopup.style.display = 'none';
      await loadInspections();
      alert('Inspection report updated.');
    } catch (err) { console.error(err); alert('Failed to update'); }
  });

  // Close popups when clicking outside
  window.addEventListener('click', function(e) {
    if (e.target === addInspectionPopup) addInspectionPopup.style.display = 'none';
    if (e.target === viewInspectionPopup) viewInspectionPopup.style.display = 'none';
    if (e.target === editInspectionPopup) editInspectionPopup.style.display = 'none';
  });

  // Initial load
  loadInspections();
});
</script>
</body>
</html>







